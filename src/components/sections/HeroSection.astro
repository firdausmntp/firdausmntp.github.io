---
import { Image } from "astro:assets";
---

<header class="header">
  <div class="profile">
    <div class="profile-img-container">
      <Image
        src="/assets/FOTOPROFILE.png"
        alt="Foto profil Firdaus Satrio Utomo"
        class="profile-img"
        width={320}
        height={320}
        loading="eager"
        decoding="async"
      />
      <div class="profile-ring"></div>
    </div>
    <div class="profile-info">
      <div class="profile-kump">
        <h1 class="name" id="typing-name">Firdaus Satrio Utomo</h1>
        <a href="/assets/CV.pdf" class="cv-download btn" download>Download CV</a>
      </div>

      <div class="title-container">
        <p class="title-main">
          <span class="title-animation">Web Developer</span>
          <span class="cursor"></span>
        </p>
        <p class="title-sub">
          <span class="learning-badge">🎯 Learning: Android Developer, Web Developer</span>
          <span class="interest-badge">🤖 Interested in: Reversed Engineering</span>
        </p>
      </div>
      <div class="contact">
        <div class="contact-item">
          <i class="fas fa-envelope" aria-hidden="true"></i>
          <a style="color: var(--primary-color)" href="mailto:firdaussatut@gmail.com">firdaussatut@gmail.com</a>
        </div>
        <div class="contact-item">
          <i class="fas fa-phone" aria-hidden="true"></i>
          <a href="https://wa.me/6281212571925" target="_blank" rel="noopener noreferrer">+62 812 1257 1925</a>
        </div>
        <div class="contact-item">
          <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
          <span>Tangerang, Indonesia</span>
        </div>
        <div class="contact-item">
          <i class="fab fa-linkedin" aria-hidden="true"></i>
          <a href="https://www.linkedin.com/in/firdaus-satrio-utomo/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
        <div class="contact-item">
          <i class="fab fa-github" aria-hidden="true"></i>
          <a href="https://github.com/firdausmntp" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </div>
  </div>
</header>
